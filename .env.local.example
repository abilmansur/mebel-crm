NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Символ валюты в интерфейсе. По умолчанию тенге (₸).
# Для РФ поставь ₽, для США $ и т.д.
NEXT_PUBLIC_CURRENCY_SYMBOL=₸

# Service Role key из Supabase: Settings -> API -> Project API keys -> service_role.
# СЕКРЕТНЫЙ — обходит Row Level Security, нужен для Telegram-вебхука и ИИ-ассистента.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- ИИ-ассистент (опционально) ---
# API-ключ Anthropic (console.anthropic.com). СЕКРЕТНЫЙ — только на сервере.
ANTHROPIC_API_KEY=sk-ant-example

# Необязательно: модель по умолчанию — claude-haiku-4-5-20251001 (дешёвая и быстрая).
# ANTHROPIC_MODEL=claude-sonnet-5

# Telegram-бота больше не нужно прописывать здесь — теперь каждый цех подключает
# СВОЕГО бота своим токеном прямо в интерфейсе (вкладка "Входящие"). См. README.
